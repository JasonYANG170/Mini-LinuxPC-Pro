# Build outputs
out/
*.o
*.ko
*.mod
*.mod.c
*.cmd
*.tmp
*.log
*.swp
*~

# Compiled binaries (but keep prebuilt firmware and rootfs)
*.bin
!device/config/chips/*/bin/*.bin
*.elf
*.img
*.gz
*.bz2
!device/config/rootfs_tar/*.tar.bz2
*.xz
*.tar
*.zip

# Kernel build artifacts
.tmp_versions/
Module.symvers
modules.order
*.order

# U-Boot build artifacts (generated files in root directory)
/u-boot.bin
/u-boot.img
/u-boot.map
/u-boot.srec
/u-boot.sym
/System.map
# Only ignore u-boot.lds in u-boot build output directory, not source files
brandy/brandy-2.0/u-boot-2018/u-boot.lds

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Temporary files
*.tmp
*.bak
*.orig
*.rej

# Note: Prebuilt firmware and rootfs are kept for building
# device/config/chips/*/bin/*.bin - Required bootloader binaries
# device/config/rootfs_tar/*.tar.bz2 - Required root filesystem archives
